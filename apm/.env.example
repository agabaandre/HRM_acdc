# =============================================================================
# APM (Approvals Management) — sample environment file
# Copy to .env and replace placeholders with real values. Never commit .env.
#   cp .env.example .env
#   php artisan key:generate
#   php artisan jwt:secret   # or set JWT_SECRET to a long random string
# =============================================================================

# --- Application ---
APP_NAME="APM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/staff/apm/
APP_TIMEZONE=Africa/Nairobi
BASE_URL=http://localhost/staff/
CI_BASE_URL=http://localhost/staff

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (MySQL typical) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apm_local
DB_USERNAME=apm_user
DB_PASSWORD=secret

# Optional: CodeIgniter Staff DB (same server, different schema as APM). If set, APM Settings → API users can mirror allow_email_login to staff `user` table.
# STAFF_DB_HOST=127.0.0.1
# STAFF_DB_PORT=3306
# STAFF_DB_DATABASE=
# STAFF_DB_USERNAME=
# STAFF_DB_PASSWORD=

# --- Session & cache ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_WARNING_TIME=3
SESSION_CHECK_INTERVAL=30

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_DRIVER=file
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- JWT (API mobile / Bearer auth) ---
JWT_SECRET=change-me-use-php-artisan-jwt-secret-or-64-char-random-string
# JWT_TTL=1440
# JWT_REFRESH_TTL=20160
# JWT_ALGO=HS256

# --- Staff portal integration (CodeIgniter session + API) ---
CI_DB_CONNECTION=mysql
CI_SESSION_TABLE=access_sessions
CI_SESSION_COOKIE_NAME=africacdc_attendance_session
CI_SESSION_ID_COLUMN=id
CI_SESSION_DATA_COLUMN=data
CI_SESSION_TIMESTAMP_COLUMN=timestamp
CI_SESSION_EXPIRATION=7200
CI_MATCH_IP=false
CI_COOKIE_PATH=/
CI_COOKIE_DOMAIN=null

STAFF_API_USERNAME=api.user@example.org
STAFF_API_PASSWORD=your-staff-api-password
# Optional shared token (config has a default if unset)
# STAFF_API_TOKEN=
# Optional absolute path to staff uploads (photos, etc.)
# STAFF_UPLOADS_PATH=/var/www/staff/uploads

# --- Mail: Microsoft Graph / Exchange OAuth (primary for APM notifications) ---
MAIL_MAILER=exchange_oauth
MAIL_DRIVER=exchange_oauth
USE_EXCHANGE_EMAIL=true
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=notifications@example.org
MAIL_PASSWORD=your-mailbox-or-app-password
MAIL_FROM_ADDRESS=notifications@example.org
MAIL_FROM_NAME="APM Notifications"
MAIL_SUBJECT_PREFIX="APM"

EXCHANGE_TENANT_ID=00000000-0000-0000-0000-000000000001
EXCHANGE_CLIENT_ID=00000000-0000-0000-0000-000000000002
EXCHANGE_CLIENT_SECRET=your-azure-client-secret-value
EXCHANGE_REDIRECT_URI=http://localhost/staff/apm/callback
EXCHANGE_SCOPE=https://graph.microsoft.com/Mail.Send
# EXCHANGE_AUTH_METHOD=client_credentials

# --- Mail: PHPMailer fallback (SMTP) ---
PHPMailer_HOST=mail.example.org
PHPMailer_USERNAME=notifications@example.org
PHPMailer_PASSWORD=your-smtp-password
PHPMailer_PORT=465
PHPMailer_FROM_ADDRESS=notifications@example.org
PHPMailer_FROM_NAME="APM Notifications"

# --- Optional Microsoft SSO (mobile / API; aliases in config) ---
# MICROSOFT_TENANT_ID=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=

# --- AWS (optional: S3, etc.) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Firebase Cloud Messaging (pending-approval pushes) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
# Default: storage/app/firebase-credentials.json
# FIREBASE_CREDENTIALS=/absolute/path/to/service-account.json

# --- Feature flags ---
ALLOW_QUARTER_CONTROL=true
ALLOW_ACTIVITY_OPERATIONS=true
SHOW_QUOTES=true
NOTIFICATION_CC_ADMIN_ASSISTANTS=true

# Audit / log retention (days; see config/audit-logger.php)
LOGS_RETENTION_PERIOD=90

# --- Vite (frontend build) ---
VITE_APP_NAME="${APP_NAME}"

# --- Optional: backup system (see config/backup.php) ---
# BACKUP_STORAGE_PATH=
# BACKUP_ONEDRIVE_ENABLED=false
# BACKUP_NOTIFICATION_EMAIL=

# --- Optional: audit logger queue ---
# AUDIT_LOGGER_QUEUE_ENABLED=false

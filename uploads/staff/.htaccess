Options -Indexes

# Block direct browser access to staff uploads. Files are served via
# application/controllers/Secure_upload.php (session + permission checks).
# Nginx: use something like
#   location ^~ /uploads/staff/ { internal; }
# and proxy to PHP, or deny all and serve only through your app.
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
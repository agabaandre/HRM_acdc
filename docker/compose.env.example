# Copy to ".env" in this repo root (docker compose + staff index.php dotenv).
#
#   cp docker/compose.env.example .env
#
# -----------------------------------------------------------------------------
# Connect to MySQL on the PHYSICAL MACHINE (default for Docker web container)
# -----------------------------------------------------------------------------
# From inside Docker, the host is reachable as host.docker.internal (macOS &
# Windows Desktop; Linux uses host-gateway via docker-compose extra_hosts).
#
DB_HOST=host.docker.internal
DB_PORT=3306

# Must match databases/users on your host MySQL (create them there if needed).
# Example local naming: staff portal DB → staff, APM DB → bms_new, user root.
DB_NAME=staff
DB_USER=root
DB_PASS=your_mysql_password

# CodeIgniter "apm" DB connection (same server as staff; second schema)
APM_DB_NAME=bms_new

COMPOSE_PROJECT_NAME=cbp-staff
APP_PORT=8080

# -----------------------------------------------------------------------------
# Optional: only if you use "docker compose --profile bundled-mysql up"
# -----------------------------------------------------------------------------
# Set DB_HOST=mysql in this file when using the bundled MySQL service.
# MYSQL_ROOT_PASSWORD=root
# MYSQL_DATABASE=staff_ci
# MYSQL_USER=staff
# MYSQL_PASSWORD=staff
# MYSQL_PUBLISH_PORT=33060

# Copy to /etc/helpdesk/helpdesk.env and edit for your server.
# Used by: helpdesk-queue.service, helpdesk-scheduler.service

# Absolute path to helpdesk/backend (Laravel app root)
HELPDESK_ROOT=/var/www/staff/helpdesk/backend

# User/group that owns Laravel storage (usually your web server user)
HELPDESK_USER=www-data
HELPDESK_GROUP=www-data

# PHP CLI binary
PHP_BIN=/usr/bin/php

# Optional: health URL used by helpdesk-health.service (adjust host/path for prod)
HELPDESK_HEALTH_URL=http://127.0.0.1/staff/helpdesk/backend/api/v1/health

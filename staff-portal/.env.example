APP_NAME="Africa CDC Staff Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/staff/staff-portal/public

STAFF_PORTAL_BASE_URL=http://localhost/staff/staff-portal/public/
BASE_URL=http://localhost/staff/
JWT_SECRET=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=staff
DB_USERNAME=root
DB_PASSWORD=

DB_MIGRATIONS_TABLE=staff_portal_migrations
DB_QUEUE_TABLE=sp_queue_jobs
DB_QUEUE_BATCHES_TABLE=sp_job_batches
DB_QUEUE_FAILED_TABLE=sp_failed_jobs

STAFF_LEGACY_SCHEMA_SKIP=true
STAFF_AUDIT_INTEGRITY_CHAIN=true
STAFF_SSO_TOKEN_TTL=7200

SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Microsoft SSO (same Azure app as CI3 — copy TENANT_ID / CLIENT_ID / CLIENT_SEC_VALUE from staff/.env)
TENANT_ID=
CLIENT_ID=
CLIENT_SEC_VALUE=
MICROSOFT_REDIRECT_URI=
ALLOW_ALTERNATIVE_LOGIN=true
APM_BASE_URL=

DB_QUEUE_TABLE=sp_queue_jobs
DB_QUEUE_BATCHES_TABLE=sp_job_batches
DB_QUEUE_FAILED_TABLE=sp_failed_jobs

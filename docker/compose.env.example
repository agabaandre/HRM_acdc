# Copy to ".env" in this repo root (docker compose + CodeIgniter staff portal).
#
#   cp docker/compose.env.example .env
#   ./docker/bootstrap.sh
#
# All modules (APM, Finance, Helpdesk, staff-portal) use the SAME MySQL database: staff
#
# -----------------------------------------------------------------------------
# Default: MySQL on the PHYSICAL HOST (your Mac / Linux machine)
# -----------------------------------------------------------------------------
DB_HOST=host.docker.internal
DB_PORT=3306

# Shared schema for every CBP module
DB_NAME=staff
DB_USER=root
DB_PASS=your_mysql_password

# CodeIgniter second connection (APM tables in the same staff schema)
APM_DB_NAME=staff

# SSO — must match across all modules
JWT_SECRET=change-me-to-a-long-random-string

# Docker web URLs (port 8080, no /staff prefix)
APP_PORT=8080
DOCKER_BASE_URL=http://localhost:8080
COMPOSE_PROJECT_NAME=cbp-staff

# Fresh bundled DB: load legacy CI3 tables from staff-portal before Laravel migrations
STAFF_LEGACY_SCHEMA_SKIP=true

# Set to 0 to stop auto-patching module .env on container start
AUTO_SYNC_MODULE_ENV=1

# -----------------------------------------------------------------------------
# Optional: bundled MySQL (./docker/bootstrap.sh --bundled-mysql)
# -----------------------------------------------------------------------------
# DB_HOST=mysql
# DB_USER=staff
# DB_PASS=staff
# MYSQL_ROOT_PASSWORD=root
# MYSQL_PUBLISH_PORT=33060

# Helpdesk installer configuration
# Copy and edit before running ./setup.sh:
#   cp setup.env.example setup.env
#
# Values here are written into helpdesk/backend/.env (existing keys are updated).

# --- URLs (Apache layout) ---
APP_URL=http://localhost/staff/helpdesk/backend
HELPDESK_FRONTEND_URL=http://localhost/staff/helpdesk
HELPDESK_STAFF_PORTAL_URL=http://localhost/staff
HELPDESK_APM_BASE_URL=http://localhost/staff/apm
BASE_URL=http://localhost/staff/

# --- Application ---
APP_ENV=local
APP_DEBUG=true

# --- Database ---
# Quick local dev without MySQL: DB_CONNECTION=sqlite (setup creates database/database.sqlite)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=helpdesk
DB_USERNAME=root
DB_PASSWORD=

# --- SSO / Staff API (leave blank to copy from ../.env or ../apm/.env when present) ---
JWT_SECRET=
SESSION_SECRET=
STAFF_API_USERNAME=
STAFF_API_PASSWORD=
STAFF_API_TOKEN=

# --- Systemd (Linux servers) ---
# auto = install on Linux when systemctl exists; true = always try; false = skip
INSTALL_SYSTEMD=auto
HELPDESK_USER=www-data
HELPDESK_GROUP=www-data
PHP_BIN=/usr/bin/php
HELPDESK_HEALTH_URL=http://127.0.0.1/staff/helpdesk/backend/api/v1/health

# --- Frontend build (production API base for Vite) ---
VITE_HELPDESK_API_BASE_URL=/staff/helpdesk/backend

# Staff portal — open this in the browser first, then use the Helpdesk card (JWT ?token=).
VITE_STAFF_PORTAL_HOME_URL=http://localhost/staff/home/index
# Base URL for shared Staff assets (Finance-style header logo). Defaults from portal URL if unset.
VITE_STAFF_BASE_URL=http://localhost/staff
# VITE_STAFF_PROFILE_URL=http://localhost/staff/auth/profile

# Where Vite's /api proxy should forward requests in `npm run dev`.
# Apache serves the Laravel helpdesk API at /staff/helpdesk/backend (see
# helpdesk/backend/.htaccess + server.php), so `php artisan serve` is not
# required for local development.
VITE_HELPDESK_API_PROXY_TARGET=http://localhost/staff/helpdesk/backend

# Optional CBP cross-links (defaults: {VITE_STAFF_BASE_URL}/apm and localhost:3002 for Finance in dev)
# VITE_APM_BASE_URL=http://localhost/staff/apm
# VITE_FINANCE_APP_URL=http://localhost:3002

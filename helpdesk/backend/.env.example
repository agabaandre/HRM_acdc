APP_NAME="Africa CDC Helpdesk API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite (default quick start): leave DB_CONNECTION=sqlite and run `touch database/database.sqlite`
# MySQL (typical with Staff/APM): set DB_CONNECTION=mysql and DB_DATABASE=helpdesk
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=helpdesk
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: try transports in order (e.g. SMTP first, then log). Matches APM-style Office 365 + fallback.
MAIL_MAILER=failover
MAIL_FAILOVER_MAILERS=smtp,log
MAIL_SCHEME=tls
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="notifications@example.org"
MAIL_FROM_NAME="${APP_NAME}"

# Microsoft 365 / Exchange OAuth (Graph) — same variable names as `apm/.env.example`; used when you wire Graph mail.
EXCHANGE_TENANT_ID=
EXCHANGE_CLIENT_ID=
EXCHANGE_CLIENT_SECRET=
EXCHANGE_REDIRECT_URI=http://localhost/staff/auth/message_callback
EXCHANGE_SCOPE=https://graph.microsoft.com/.default
EXCHANGE_AUTH_METHOD=client_credentials

# JWT_SECRET must match Staff portal root .env (same HS256 SSO token as Finance / APM from home/index).
JWT_SECRET=change-me-copy-exact-value-from-staff-root-env
JWT_TTL=1440
SESSION_SECRET=change-me-align-with-finance-session-secret-if-needed

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

HELPDESK_STAFF_PORTAL_URL=http://localhost/staff
HELPDESK_APM_BASE_URL=http://localhost/staff/apm
HELPDESK_FRONTEND_URL=http://localhost:5174

# Shared Staff uploads tree (same as APM STAFF_PORTAL_UPLOADS_ROOT): {root}/staff/{photo basename}
# Default: repo `uploads/` next to `helpdesk/` when Helpdesk lives under `staff/helpdesk/backend`.
# HELPDESK_STAFF_UPLOADS_ROOT=/var/www/staff/uploads
# When SPA and API use different hosts, set absolute API origin for <img src> avatar URLs:
# HELPDESK_API_PUBLIC_URL=https://api.example.org
# HELPDESK_AVATAR_SIGNED_TTL=604800
# HELPDESK_AVATAR_SIGNING_SECRET=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5174,127.0.0.1,127.0.0.1:5174

HELPDESK_BRIDGE_SECRET=change-me-server-side-only-shared-with-ci-apm-for-auth-exchange

# Comma-separated Staff permission IDs (default 85=APM, 92=Finance, 93=Helpdesk-only card).
HELPDESK_SSO_PERMISSION_CODES=85,92,93
# Staff user_groups.id values mapped to Helpdesk admin when JWT has no helpdesk_role (default 10 = portal admin).
HELPDESK_SSO_STAFF_ROLE_IDS_ADMIN=10
# Staff division_id values that become Helpdesk agents on SSO (default 21).
HELPDESK_DEFAULT_AGENT_DIVISION_IDS=21

# --- Staff Share API (directory sync + agent requester picker) ---
# Use the SAME variables as APM (`apm/.env` / `apm/.env.example`): `config/helpdesk.php` reads them when
# `HELPDESK_STAFF_API_*` is omitted. Copy this block from your working APM `.env` so staff + divisions sync match.
# STAFF_API_USERNAME = Staff portal user LOGIN EMAIL for Share API Basic Auth (see Share.php api_login), not a free-form label.
# STAFF_API_PASSWORD = that user's current password. Placeholders return 401 "Invalid credentials" from Staff.
BASE_URL=http://localhost/staff/
STAFF_API_USERNAME=api.user@example.org
STAFF_API_PASSWORD=your-staff-api-password
# Optional; default token matches APM `config/services.php` if unset in both apps:
# STAFF_API_TOKEN=YWZyY2FjZGNzdGFmZnRyYWNrZXI
# Optional absolute staff root if different from BASE_URL (overrides BASE_URL for API calls only):
# STAFF_API_BASE_URL=http://localhost/staff
# Helpdesk-specific overrides (take precedence over STAFF_API_* / BASE_URL when set):
# HELPDESK_STAFF_API_BASE_URL=http://localhost/staff
# HELPDESK_STAFF_API_TOKEN=
# HELPDESK_STAFF_API_USERNAME=
# HELPDESK_STAFF_API_PASSWORD=
# Endpoint paths default to APM `services.staff_api.endpoints` (/share/divisions, /share/directorates, /share/get_current_staff):
# HELPDESK_STAFF_API_ENDPOINT_STAFF=/share/get_current_staff
# HELPDESK_STAFF_API_ENDPOINT_DIVISIONS=/share/divisions
# HELPDESK_STAFF_API_ENDPOINT_DIRECTORATES=/share/directorates
# HELPDESK_STAFF_API_STAFF_LIMIT=5000
# HELPDESK_REFERENCE_CACHE_TTL=300

# --- Logging (ISO-friendly JSON Lines, optional) ---
# Add the iso_json channel to the stack so security-relevant log lines are written as JSON to storage/logs/helpdesk-iso.jsonl
# (UTC timestamps; suitable for SIEM ingestion and ISO/IEC 27001 evidence). See config/logging.php.
# LOG_STACK=single,iso_json
